<ace_development_guide>
  <overview>
    This guide covers the complete development workflow for IBM App Connect Enterprise (ACE) v13,
    including message flow patterns and ace-bob skill integration. It provides step-by-step guidance
    from project creation to deployment-ready artifacts.
  </overview>

  <!-- ========================================
       SECTION 1: DEVELOPMENT WORKFLOW
       ======================================== -->
  
  <development_workflow>
    <initialization>
      <step number="1">
        <title>Understand Requirements</title>
        <description>Gather complete information about the integration requirement</description>
        <actions>
          <action>Identify source and target systems</action>
          <action>Understand message formats (XML, JSON, CSV, etc.)</action>
          <action>Determine integration pattern (request-reply, fire-and-forget, pub-sub)</action>
          <action>Identify error handling requirements</action>
          <action>Understand audit and logging needs</action>
          <action>Determine environment-specific configurations</action>
        </actions>
      </step>

      <step number="2">
        <title>Analyze Existing Patterns</title>
        <description>Check for similar implementations in the codebase</description>
        <tools>
          <tool>search_files - Find similar message flows or ESQL patterns</tool>
          <tool>read_file - Examine existing implementations</tool>
          <tool>list_files - Understand project structure</tool>
        </tools>
        <rationale>
          Reusing proven patterns ensures consistency and reduces development time
        </rationale>
      </step>
    </initialization>

    <project_setup>
      <phase name="project_creation">
        <description>Create or identify the ACE project structure</description>
        <steps>
          <step>
            <title>Determine Project Type</title>
            <options>
              <option>Application Project - For deployable message flows</option>
              <option>Library Project - For reusable subflows and ESQL modules</option>
              <option>Shared Library - For common utilities across applications</option>
            </options>
          </step>

          <step>
            <title>Create Project Structure</title>
            <required_files>
              <file>.project - Eclipse project descriptor</file>
              <file>application.descriptor or library.descriptor</file>
              <file>.settings/org.eclipse.core.resources.prefs</file>
              <file>pom.xml - Maven configuration (optional but recommended)</file>
            </required_files>
            <directory_structure>
              <directory>com/[organization]/esb/ - Main package for flows and ESQL</directory>
              <directory>properties/ - Environment-specific properties</directory>
            </directory_structure>
          </step>

          <step>
            <title>Configure Dependencies</title>
            <description>Reference shared libraries in application.descriptor</description>
            <common_libraries>
              <library>Common error handling library</library>
              <library>Audit logging library</library>
              <library>Utility functions library</library>
            </common_libraries>
          </step>
        </steps>
      </phase>
    </project_setup>

    <development_phases>
      <phase name="message_flow_design">
        <description>Design the message flow structure</description>
        <steps>
          <step number="1">
            <title>Identify Input Node</title>
            <common_inputs>
              <input>MQ Input - For queue-based messaging</input>
              <input>HTTP Input - For REST/SOAP services</input>
              <input>File Input - For file-based integration</input>
              <input>Database Input - For database polling</input>
            </common_inputs>
          </step>

          <step number="2">
            <title>Design Processing Logic</title>
            <pattern_considerations>
              <consideration>Use subflows for reusable logic</consideration>
              <consideration>Implement error handling at flow level</consideration>
              <consideration>Add audit points for tracking</consideration>
              <consideration>Consider transaction boundaries</consideration>
            </pattern_considerations>
          </step>

          <step number="3">
            <title>Configure Output Nodes</title>
            <common_outputs>
              <output>MQ Output - For queue-based messaging</output>
              <output>HTTP Reply/Request - For synchronous responses</output>
              <output>File Output - For file generation</output>
              <output>Database - For data persistence</output>
            </common_outputs>
          </step>

          <step number="4">
            <title>Implement Error Handling</title>
            <required_elements>
              <element>Catch terminal connections</element>
              <element>Error subflow invocation</element>
              <element>Email notification for critical errors</element>
              <element>Audit logging of errors</element>
            </required_elements>
          </step>
        </steps>
      </phase>

      <phase name="esql_development">
        <description>Develop ESQL code for Compute nodes</description>
        <steps>
          <step>
            <title>Create ESQL Module</title>
            <structure>
              <element>BROKER SCHEMA declaration</element>
              <element>EXTERNAL variable declarations</element>
              <element>Module definitions with Main() function</element>
              <element>Helper procedures</element>
            </structure>
          </step>

          <step>
            <title>Implement Business Logic</title>
            <best_practices>
              <practice>Use REFERENCE for tree navigation</practice>
              <practice>Minimize tree copying operations</practice>
              <practice>Declare variables at appropriate scope</practice>
              <practice>Use meaningful variable names</practice>
              <practice>Add comprehensive comments</practice>
            </best_practices>
          </step>

          <step>
            <title>Add Error Handling</title>
            <techniques>
              <technique>Use TRY-CATCH blocks for exception handling</technique>
              <technique>Set Environment variables for error context</technique>
              <technique>Return appropriate status codes</technique>
            </techniques>
          </step>
        </steps>
      </phase>

      <phase name="audit_implementation">
        <description>Implement audit logging following enterprise patterns</description>
        <steps>
          <step>
            <title>Initialize Audit Parameters</title>
            <required_fields>
              <field>MsgId - Unique message identifier</field>
              <field>CorrelId - Correlation identifier</field>
              <field>Status - Success/Failure status</field>
              <field>MsgFlowName - Flow name</field>
              <field>ApplicationName - Application name</field>
              <field>Keydata - Business key information</field>
              <field>Comments - Processing comments</field>
            </required_fields>
          </step>

          <step>
            <title>Call Audit Subflow</title>
            <description>Invoke common audit subflow at key processing points</description>
          </step>
        </steps>
      </phase>

      <phase name="properties_configuration">
        <description>Configure environment-specific properties</description>
        <steps>
          <step>
            <title>Create Properties Files</title>
            <environments>
              <environment>DEV.properties</environment>
              <environment>QA.properties</environment>
              <environment>UAT.properties</environment>
              <environment>PROD.properties</environment>
            </environments>
          </step>

          <step>
            <title>Define Properties</title>
            <common_properties>
              <property>Queue names</property>
              <property>HTTP endpoints</property>
              <property>File paths</property>
              <property>Database connection details</property>
              <property>Email addresses</property>
              <property>Timeout values</property>
              <property>Retry counts</property>
            </common_properties>
          </step>
        </steps>
      </phase>
    </development_phases>
  </development_workflow>

  <!-- ========================================
       SECTION 2: MESSAGE FLOW PATTERNS
       ======================================== -->

  <message_flow_patterns>
    <fundamental_principles>
      <principle priority="critical">
        <name>Use ace-bob Skill for Flow Creation</name>
        <description>
          ALWAYS use the ace-bob skill to create .msgflow files. Never manually construct
          message flow XML without consulting the skill for correct xmi:type namespace prefixes.
        </description>
        <rationale>
          The ace-bob skill contains the authoritative list of node types and their correct
          xmi:type values. Manual construction often leads to incorrect namespace prefixes.
        </rationale>
      </principle>

      <principle priority="high">
        <name>Error Handling at Flow Level</name>
        <description>
          Connect Catch terminals at the flow level rather than individual node level
        </description>
        <rationale>
          Cleaner flow design, centralized error handling, easier maintenance
        </rationale>
      </principle>

      <principle priority="high">
        <name>Subflow Reusability</name>
        <description>
          Extract common patterns into subflows for reuse across multiple flows
        </description>
        <benefits>
          <benefit>Consistency across implementations</benefit>
          <benefit>Easier maintenance and updates</benefit>
          <benefit>Reduced development time</benefit>
          <benefit>Standardized error handling and audit</benefit>
        </benefits>
      </principle>
    </fundamental_principles>

    <common_flow_patterns>
      <pattern name="request_reply_http">
        <description>
          Synchronous HTTP request-reply pattern for REST/SOAP services
        </description>
        <structure>
          <node>HTTP Input - Receive request</node>
          <node>Compute - Initialize audit parameters</node>
          <node>Compute - Transform request</node>
          <node>HTTP Request - Call backend service</node>
          <node>Compute - Transform response</node>
          <node>HTTP Reply - Send response</node>
          <node>Catch - Error handling</node>
        </structure>
        <key_considerations>
          <consideration>Set appropriate timeout values</consideration>
          <consideration>Handle HTTP error codes</consideration>
          <consideration>Implement retry logic if needed</consideration>
          <consideration>Log request/response for audit</consideration>
        </key_considerations>
      </pattern>

      <pattern name="mq_to_mq">
        <description>
          Asynchronous message transformation between MQ queues
        </description>
        <structure>
          <node>MQ Input - Read from input queue</node>
          <node>Compute - Initialize audit</node>
          <node>Compute - Transform message</node>
          <node>MQ Output - Write to output queue</node>
          <node>Compute - Update audit (success)</node>
          <node>Catch - Error handling</node>
        </structure>
        <key_considerations>
          <consideration>Configure transaction boundaries</consideration>
          <consideration>Handle poison messages</consideration>
          <consideration>Set backout queue</consideration>
          <consideration>Consider message persistence</consideration>
        </key_considerations>
      </pattern>

      <pattern name="file_processing">
        <description>
          File-based integration with polling and processing
        </description>
        <structure>
          <node>File Input - Poll directory</node>
          <node>Compute - Initialize audit with filename</node>
          <node>Compute - Parse and transform file content</node>
          <node>File Output or MQ Output - Write result</node>
          <node>Compute - Update audit (success)</node>
          <node>Catch - Error handling and file archival</node>
        </structure>
        <key_considerations>
          <consideration>Configure file polling interval</consideration>
          <consideration>Handle large files efficiently</consideration>
          <consideration>Implement file archival strategy</consideration>
          <consideration>Handle file locking issues</consideration>
          <consideration>Generate dynamic output filenames</consideration>
        </key_considerations>
      </pattern>

      <pattern name="database_polling">
        <description>
          Poll database for new records and process them
        </description>
        <structure>
          <node>Database Input - Poll for records</node>
          <node>Compute - Initialize audit</node>
          <node>Compute - Process record</node>
          <node>HTTP Request or MQ Output - Send to target</node>
          <node>Database - Update record status</node>
          <node>Compute - Update audit</node>
          <node>Catch - Error handling</node>
        </structure>
        <key_considerations>
          <consideration>Use appropriate SQL for polling</consideration>
          <consideration>Implement record locking mechanism</consideration>
          <consideration>Handle transaction boundaries</consideration>
          <consideration>Consider batch processing for performance</consideration>
        </key_considerations>
      </pattern>

      <pattern name="aggregation">
        <description>
          Aggregate multiple messages before processing
        </description>
        <structure>
          <node>MQ Input - Receive messages</node>
          <node>Aggregate Control - Define aggregation</node>
          <node>Aggregate Request - Collect messages</node>
          <node>Compute - Process aggregated messages</node>
          <node>Aggregate Reply - Send result</node>
        </structure>
        <key_considerations>
          <consideration>Define aggregation timeout</consideration>
          <consideration>Set maximum message count</consideration>
          <consideration>Handle partial aggregations</consideration>
          <consideration>Consider memory implications</consideration>
        </key_considerations>
      </pattern>

      <pattern name="scatter_gather">
        <description>
          Send request to multiple services and gather responses
        </description>
        <structure>
          <node>HTTP Input - Receive request</node>
          <node>Group Scatter - Fan out to multiple services</node>
          <node>HTTP Request (multiple) - Call services</node>
          <node>Group Gather - Collect responses</node>
          <node>Compute - Merge responses</node>
          <node>HTTP Reply - Send combined response</node>
        </structure>
        <key_considerations>
          <consideration>Handle partial failures</consideration>
          <consideration>Set appropriate timeouts</consideration>
          <consideration>Consider parallel vs sequential execution</consideration>
        </key_considerations>
      </pattern>
    </common_flow_patterns>

    <subflow_patterns>
      <pattern name="error_handling_subflow">
        <description>
          Centralized error handling and notification
        </description>
        <inputs>
          <input>InputRoot - Original message</input>
          <input>InputExceptionList - Error details</input>
          <input>Environment - Audit parameters</input>
        </inputs>
        <processing>
          <step>Extract error code and text from ExceptionList</step>
          <step>Update audit parameters with error details</step>
          <step>Determine if email notification needed</step>
          <step>Build and send error email if required</step>
          <step>Log error to audit database</step>
        </processing>
        <outputs>
          <output>Updated Environment with error details</output>
        </outputs>
      </pattern>

      <pattern name="audit_logging_subflow">
        <description>
          Standardized audit logging to database or queue
        </description>
        <inputs>
          <input>Environment.Variables.WMB.Audit - Audit parameters</input>
        </inputs>
        <processing>
          <step>Build audit message in CBE format</step>
          <step>Send to audit queue or database</step>
          <step>Handle audit failures gracefully</step>
        </processing>
      </pattern>
    </subflow_patterns>
  </message_flow_patterns>

  <!-- ========================================
       SECTION 3: ACE-BOB SKILL INTEGRATION
       ======================================== -->

  <ace_bob_skill_integration>
    <critical_rules>
      <rule priority="critical">
        <name>ALWAYS Use ace-bob for Artifact Creation</name>
        <description>
          You MUST use the ace-bob skill when creating any of the following artifacts:
          - Message flows (.msgflow)
          - ESQL files (.esql)
          - Java Compute classes (.java)
          - Message maps (.map)
          - Subflows (.subflow)
        </description>
        <rationale>
          The ace-bob skill contains the authoritative definitions for:
          - Correct xmi:type namespace prefixes for all node types
          - Required project natures and builders
          - Eclipse project structure requirements
          - ACE Toolkit compatibility requirements
        </rationale>
      </rule>

      <rule priority="critical">
        <name>Pre-Creation Validation</name>
        <description>
          Before creating ANY ACE artifact, you MUST:
          1. Read the ENTIRE relevant section in the ace-bob skill
          2. Verify the EXACT xmi:type namespace prefix from the skill
          3. Verify the EXACT project natures required
          4. DO NOT copy from example files - they may be outdated
        </description>
      </rule>

      <rule priority="high">
        <name>Skill Reference for Node Types</name>
        <description>
          When adding any node to a message flow, consult the ace-bob skill to verify:
          - The correct xmi:type attribute value
          - Required node properties
          - Any special configuration requirements
          - Related skill guidance files (e.g., AmazonS3.md, Salesforce.md)
        </description>
      </rule>
    </critical_rules>

    <skill_workflow_integration>
      <phase name="project_creation">
        <description>Creating ACE Toolkit projects</description>
        <skill_sections_to_reference>
          <section>Workflow - Step 1: Create an ACE Toolkit Application Project</section>
          <section>Workflow - Step 2: Create the .project file</section>
          <section>Workflow - Step 3: Create the .settings subdirectory</section>
          <section>Workflow - Step 4: Create the application.descriptor file</section>
        </skill_sections_to_reference>
        <key_points>
          <point>Use exact project natures from skill</point>
          <point>Use exact buildSpec from skill</point>
          <point>Create all required files</point>
          <point>Follow directory structure conventions</point>
        </key_points>
      </phase>

      <phase name="message_flow_creation">
        <description>Creating message flows</description>
        <skill_sections_to_reference>
          <section>Workflow - Step 5: Create a message flow</section>
          <section>Node-specific xmi:type definitions (extensive list in skill)</section>
        </skill_sections_to_reference>
        <process>
          <step>Identify required nodes for the flow</step>
          <step>For EACH node, look up its xmi:type in the ace-bob skill</step>
          <step>Verify any special attributes (e.g., applicationConnectorType)</step>
          <step>Check for related guidance files (e.g., Box.md, GitHub.md)</step>
          <step>Use the skill to generate the .msgflow file</step>
        </process>
      </phase>

      <phase name="esql_creation">
        <description>Creating ESQL files</description>
        <skill_sections_to_reference>
          <section>Workflow - Step 6: Create an ESQL file</section>
        </skill_sections_to_reference>
        <best_practices_from_skill>
          <practice>Use efficient ESQL coding techniques</practice>
          <practice>Ensure proper use of REFERENCE vs VALUE</practice>
          <practice>Be aware of memory management</practice>
          <practice>Optimize for performance</practice>
        </best_practices_from_skill>
      </phase>
    </skill_workflow_integration>

    <node_type_lookup_process>
      <description>
        How to correctly determine node types when creating message flows
      </description>

      <step number="1">
        <action>Identify the node you need to add</action>
        <example>Need to add an HTTP Input node</example>
      </step>

      <step number="2">
        <action>Search the ace-bob skill for the node type</action>
        <search_pattern>Search for "If you add a [NodeName] node"</search_pattern>
        <example>Search for "If you add a HTTP Input node"</example>
      </step>

      <step number="3">
        <action>Extract the exact xmi:type value</action>
        <example>
          Found: "If you add a HTTP Input node to a message flow, it MUST have an 
          xmi:type attribute using the namespace prefix of ComIbmWSInput.msgnode"
          
          Therefore: xmi:type="ComIbmWSInput.msgnode:FCMComposite_1_1"
        </example>
      </step>

      <step number="4">
        <action>Check for additional required attributes</action>
        <example>
          For Application Connector nodes, also need applicationConnectorType attribute
        </example>
      </step>

      <step number="5">
        <action>Check for related guidance files</action>
        <example>
          "If you add a Salesforce Request node to a message flow you MUST read the 
          skill guidance in Salesforce.md to help determine the node properties"
        </example>
      </step>
    </node_type_lookup_process>

    <common_node_types_reference>
      <description>
        Quick reference for frequently used nodes (always verify in ace-bob skill)
      </description>

      <category name="input_nodes">
        <node name="HTTP Input" xmi_type="ComIbmWSInput.msgnode"/>
        <node name="MQ Input" xmi_type="ComIbmMQInput.msgnode"/>
        <node name="File Input" xmi_type="ComIbmFileInput.msgnode"/>
        <node name="Database Input" xmi_type="ComIbmDatabaseInput.msgnode"/>
        <node name="SOAP Input" xmi_type="ComIbmSOAPInput.msgnode"/>
      </category>

      <category name="processing_nodes">
        <node name="Compute" xmi_type="ComIbmCompute.msgnode"/>
        <node name="Java Compute" xmi_type="ComIbmJavaCompute.msgnode"/>
        <node name="Mapping" xmi_type="ComIbmMapping.msgnode"/>
        <node name="Filter" xmi_type="ComIbmFilter.msgnode"/>
      </category>

      <category name="output_nodes">
        <node name="HTTP Reply" xmi_type="ComIbmWSReply.msgnode"/>
        <node name="HTTP Request" xmi_type="ComIbmWSRequest.msgnode"/>
        <node name="MQ Output" xmi_type="ComIbmMQOutput.msgnode"/>
        <node name="File Output" xmi_type="ComIbmFileOutput.msgnode"/>
        <node name="Database" xmi_type="ComIbmDatabase.msgnode"/>
      </category>

      <category name="routing_nodes">
        <node name="Route" xmi_type="ComIbmRoute.msgnode"/>
        <node name="RouteToLabel" xmi_type="ComIbmRouteToLabel.msgnode"/>
        <node name="Label" xmi_type="ComIbmLabel.msgnode"/>
      </category>
    </common_node_types_reference>
  </ace_bob_skill_integration>
</ace_development_guide>

